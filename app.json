{
  "expo": {
    "name": "lumina",
    "slug": "lumina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lumina",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAFA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumina.skincare",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Lumina needs camera access for skin progress photos.",
        "NSPhotoLibraryUsageDescription": "Lumina needs photo library access for skin progress photos."
      }
    },
    "android": {
      "package": "com.lumina.skincare",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFA",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
